# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android (Gradle/Android Studio)
**/android/.gradle/
**/android/.idea/
**/android/.settings/
**/android/.classpath
**/android/.project
**/android/**/local.properties
**/android/**/captures/

# Android signing keys (DO NOT COMMIT)
**/*.jks
**/*.keystore
**/key.properties
**/keystore.properties
**/upload-keystore.jks

# iOS (Xcode/CocoaPods)
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/ephemeral/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/Flutter.podspec
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/**/xcuserdata/
**/ios/**/*.xcuserstate
**/ios/**/*.pbxuser
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.perspectivev3

# macOS / Xcode DerivedData
DerivedData/

# iOS signing / certificates / provisioning (DO NOT COMMIT)
**/*.p12
**/*.p8
**/*.cer
**/*.crt
**/*.der
**/*.key
**/*.mobileprovision
**/*.pfx

# Fastlane artifacts (optional)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# Environment / secrets (DO NOT COMMIT)
.env
.env.*
!.env.example
!.env.sample
!.env.template
!.env.defaults
.secrets
.secrets.*
*.pem
*.pkcs12
